#!/bin/sh
set -e

ENVFILE="-"

while :; do
    case $1 in
        -e|--export) EXPORT=1; shift ;;
        -i|--ignore) IGNORE=1; shift ;;
        -f|--file)   ENVFILE="$2"; shift 2 ;;
        --) break ;;
        -*) echo "Invalid option $1"; exit 1 ;;
        *) break ;;
    esac
done

subst() {
    cat "$1" \
      | { tee /dev/fd/3 \
        | sha1sum \
        | awk '{print "SHA1SUM=" $1}'; \
        } 3>&1 \
      | tail -r \
      | xargs sh -c 'printf "%s\n" "${@}" | tail -r | env "$0" envsubst' --
}

if [ "$IGNORE" = 1 ]; then
    ENVARGS="-i"
fi

if [ "$EXPORT" = 1 ]; then
    subst "$ENVFILE" | sed 's/^\([^=]*\)=\(.*\)$/export \1="\2"/'
    exit 0
fi

fifo="$(mktemp -d)/fifo"
mkfifo "$fifo"
(
    subst "$ENVFILE" | tr '\n' '\0'
    [ "$#" -gt 0 ] && printf "%s\0" "$@"
    rm -rf "$(dirname "$fifo")"
) >> "$fifo" &

exec xargs -0 -a "$fifo" env $ENVARGS
